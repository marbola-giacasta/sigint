{
  "compilerOptions": {
    "target":                       "ES2022",
    "module":                       "NodeNext",
    "moduleResolution":             "NodeNext",
    "outDir":                       "./dist",
    "rootDir":                      "./src",
    "strict":                       false,
    "noImplicitAny":                false,
    "esModuleInterop":              true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule":            true,
    "skipLibCheck":                 true,
    "allowJs":                      true,
    "checkJs":                      false,
    "sourceMap":                    true,
    "types":                        ["node"]
  },
  "include":  ["src/**/*"],
  "exclude":  ["node_modules", "dist"]
}
