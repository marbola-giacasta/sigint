{
  "name": "social-scraper-ts",
  "version": "5.0.0",
  "type": "module",
  "description": "Instagram, YouTube, Reddit & X scraper with Web UI \u2014 TypeScript edition",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');const src='public',dst='dist/public';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dst,f)));console.log('Copied public/ \u2192 dist/public/')\"",
    "start": "npm run build && node dist/index.js",
    "ui": "npm run build && node dist/uiServer.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "inquirer": "^8.2.6",
    "puppeteer": "^21.0.0",
    "puppeteer-core": "^21.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "@types/express-session": "^1.17.10",
    "@types/bcryptjs": "^2.4.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}